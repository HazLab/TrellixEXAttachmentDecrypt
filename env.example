# Copy to .env and fill in real values:  cp env.example .env
# .env is gitignored and never committed. Values shown are defaults/examples.

# ============================================================
# Trellix EX appliance  (REQUIRED)
# ============================================================
EX_BASE_URL=https://ex.example.com
EX_USERNAME=api_analyst
EX_PASSWORD=
# Set to false only for self-signed lab appliances.
EX_VERIFY_TLS=true

# ============================================================
# What triggers the flow
# An alert fires the recovery flow only when its top-level "name" equals
# TRIGGER_ALERT_NAME (the riskware-object detection) AND one of its malware
# names exactly equals one of the comma-separated TRIGGER_MALWARE_NAMES.
# The encrypted-attachment custom policy emits CustomPolicy.MVX.<ext>.
# (Empty TRIGGER_MALWARE_NAMES disables triggering entirely.)
# ============================================================
TRIGGER_ALERT_NAME=RISKWARE_OBJECT
TRIGGER_MALWARE_NAMES=CustomPolicy.MVX.pdf,CustomPolicy.MVX.zip,CustomPolicy.MVX.docx

# ============================================================
# Outbound mail (SMTP)  (SMTP_HOST required)
# ============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=attachment-help@example.com
SMTP_STARTTLS=true

# ============================================================
# Web server / one-time links
# ============================================================
# Public base URL used to build the password link emailed to recipients.
PUBLIC_BASE_URL=https://decrypt.example.com
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Signs the one-time tokens — set to a long random string in production.
SECRET_KEY=change-me
# Link lifetime in seconds (default 24h).
TOKEN_TTL=86400

# ============================================================
# Webhook auth (EX -> this service)
# ============================================================
# EX must send this as the X-Webhook-Secret header.
WEBHOOK_SECRET=change-me
# Optional comma-separated source-IP allowlist (empty = allow any).
WEBHOOK_IP_ALLOWLIST=

# ============================================================
# Flow tuning
# ============================================================
# Max password retries before giving up (recommended 3-5).
MAX_PASSWORD_ATTEMPTS=3
# Seconds to wait after resubmission before the first recheck.
RECHECK_DELAY=120
# Seconds between recheck polls.
RECHECK_INTERVAL=60
# Number of polls before concluding "not re-quarantined = clean".
RECHECK_MAX_ATTEMPTS=10

# ============================================================
# Storage
# ============================================================
DB_URL=sqlite:///trellix_decrypt.sqlite3
