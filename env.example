# Copy to .env and fill in real values:  cp env.example .env
# .env is gitignored and never committed. Values shown are defaults/examples.

# ============================================================
# Trellix EX appliance  (REQUIRED)
# ============================================================
EX_BASE_URL=https://ex.example.com
EX_USERNAME=api_analyst
EX_PASSWORD=
# Set to false only for self-signed lab appliances.
EX_VERIFY_TLS=true
# Optional X-FeClient-Token (provided by Trellix); leave blank if unused.
EX_CLIENT_TOKEN=

# ============================================================
# What triggers the flow
# An alert fires the recovery flow only when its top-level "name" equals
# TRIGGER_ALERT_NAME (the riskware-object detection) AND one of its malware
# names exactly equals one of the comma-separated TRIGGER_MALWARE_NAMES.
# The encrypted-attachment custom policy emits CustomPolicy.MVX.<ext>.
# (Empty TRIGGER_MALWARE_NAMES disables triggering entirely.)
# ============================================================
TRIGGER_ALERT_NAME=RISKWARE_OBJECT
TRIGGER_MALWARE_NAMES=CustomPolicy.MVX.pdf,CustomPolicy.MVX.zip,CustomPolicy.MVX.docx,CustomPolicy.MVX.65066.PassExtractFailed

# ============================================================
# Outbound mail (SMTP)  (SMTP_HOST required)
# ============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=attachment-help@example.com
# TLS mode: opportunistic (STARTTLS if offered, else plaintext) | starttls
# (require STARTTLS) | none (plaintext only) | ssl (implicit TLS/SMTPS, e.g. 465).
SMTP_TLS_MODE=opportunistic
# HELO/EHLO name sent to the server. Leave blank to use the OS hostname; set a
# fully-qualified name if the server rejects with "504 5.5.2 need FQDN".
SMTP_HELO_HOSTNAME=

# ============================================================
# Web server / one-time links
# ============================================================
# Public base URL used to build the password link emailed to recipients.
PUBLIC_BASE_URL=https://decrypt.example.com
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Signs one-time tokens, UI sessions, and encrypts stored settings secrets.
# Set to a long random string in production (changing it invalidates saved secrets).
SECRET_KEY=change-me
# Admin password for the dashboard/settings UI. Unset = UI sign-in disabled.
UI_PASSWORD=
# Link lifetime in seconds (default 24h).
TOKEN_TTL=86400

# ============================================================
# Webhook auth (EX HTTP notification -> this service)
# EX posts alerts using HTTP Basic auth; set matching credentials on the
# EX HTTP notification consumer. Optionally also restrict by source IP.
# At least one of (username/password) or (IP allowlist) must be set.
# ============================================================
WEBHOOK_USERNAME=ex-webhook
WEBHOOK_PASSWORD=change-me
# Optional comma-separated source-IP allowlist (empty = don't restrict by IP).
WEBHOOK_IP_ALLOWLIST=

# ============================================================
# Flow tuning
# ============================================================
# Max password retries before giving up (recommended 3-5).
MAX_PASSWORD_ATTEMPTS=3
# Seconds to wait after resubmission before the first recheck.
RECHECK_DELAY=120
# Seconds between recheck polls.
RECHECK_INTERVAL=60
# Number of polls before concluding "not re-quarantined = clean".
RECHECK_MAX_ATTEMPTS=10
# Auto-retry of failed recipient emails (SMTP errors): cap + sweep interval.
NOTIFY_MAX_RETRIES=5
NOTIFY_RETRY_INTERVAL=300

# ============================================================
# Storage
# ============================================================
DB_URL=sqlite:///trellix_decrypt.sqlite3

# ============================================================
# Bounce monitoring (optional) — poll the sender mailbox over IMAP for delivery
# failures (DSNs) and flip the case to "Bounced". Leave IMAP_HOST blank to disable.
# ============================================================
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_SSL=true
IMAP_MAILBOX=INBOX
BOUNCE_POLL_INTERVAL=120

# ============================================================
# Logging
# ============================================================
# INFO is fine; set DEBUG for verbose troubleshooting.
LOG_LEVEL=INFO
