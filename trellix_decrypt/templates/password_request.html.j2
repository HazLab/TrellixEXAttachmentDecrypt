<!doctype html>
<html lang="en">
<body style="font-family: Arial, sans-serif; color: #222; line-height: 1.5;">
  <p>
    {% if retry %}
      The password you provided didn&rsquo;t unlock the attachment. Please try again.
    {% else %}
      One of your incoming emails has a password-protected attachment that our
      security system could not open.
    {% endif %}
  </p>
  <p>To release it, please enter the attachment password using the secure link below:</p>
  <p>
    <a href="{{ link }}" style="background:#1a73e8;color:#fff;padding:10px 18px;border-radius:6px;text-decoration:none;">
      Enter attachment password
    </a>
  </p>
  {% if case.subject %}<p style="color:#666;">Email subject: {{ case.subject }}</p>{% endif %}
  <p style="color:#888;font-size:12px;">
    This link is single-use and will expire. If you didn&rsquo;t expect this email, you can ignore it.
  </p>
</body>
</html>
